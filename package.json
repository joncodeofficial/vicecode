{
  "name": "vicecode",
  "displayName": "ViceCode",
  "description": "GTA Vice City WASM inside VS Code",
  "version": "1.2.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vicecodeContainer",
          "title": "GTA",
          "icon": "media/vc-icon.svg"
        }
      ]
    },
    "views": {
      "vicecodeContainer": [
        {
          "type": "webview",
          "id": "vicecode.gameView",
          "name": "VICE CITY WASM",
          "icon": "media/vc-icon.svg"
        }
      ]
    }
  },
  "icon": "media/icon.png",
  "publisher": "Jonpena",
  "repository": {
    "type": "git",
    "url": "https://github.com/joncodeofficial/vicecode.git"
  },
  "scripts": {
    "lint": "eslint .",
    "package": "mkdir -p dist && vsce package --out ./dist/"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "eslint": "^9.39.3",
    "semantic-release": "^24.2.5"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45"
  }
}
